#!/bin/bash

# --- Color Palette (Modern & Vibrant) ---
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
WHITE='\033[1;37m'
GRAY='\033[0;90m'
NC='\033[0m'
BOLD='\033[1m'

# --- Configuration ---
DOTFILES_REPO="$HOME/dotfiles"
CONFIG_SRC="$HOME/.config"
CONFIG_DEST="$DOTFILES_REPO/config"

# --- Data Declaration ---
# Format: "Asal:Tujuan:Mode" (merge/replace)
CONFIG_LIST=(
    "nvim:nvim:merge"
    "awesome:awesome:merge"
    "kitty:kitty:merge"
    "niri:niri:merge"
    "VSCodium:VSCodium:merge"
    "gtk-3.0:gtk-3.0:merge"
#    "i3:i3:merge"
#    "kitty:kitty:merge"
#    "polybar:polybar:replace"
#    "rofi:rofi:merge"
)

HOME_FILES=(
    ".bashrc:bashrc"
#    ".zshrc:zshrc"
    ".gitconfig:gitconfig"
    ".tmux.conf:tmux.conf"
)

# --- UI Helpers ---
draw_sep() { echo -e "${GRAY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"; }

print_status() {
    local label=$1
    local mode=$2
    local status=$3
    local color=$4
    printf "  ${WHITE}%-18s${NC} ${GRAY}│${NC} %-10s ${GRAY}│${NC} ${color}%-10s${NC}\n" "$label" "$mode" "$status"
}

header() {
    clear
    echo -e "${MAGENTA}${BOLD}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${NC}"
    echo -e "${MAGENTA}${BOLD}┃${NC}          ${WHITE}✨  MODERN DOTFILES MANAGER  ✨${NC}          ${MAGENTA}${BOLD}┃${NC}"
    echo -e "${MAGENTA}${BOLD}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${NC}"
}

# --- Core Functions ---
restore() {
    header
    echo -e "${CYAN}${BOLD} 📥 DEPLOYING CONFIGURATIONS${NC}"
    draw_sep
    printf "  ${BOLD}%-18s ${GRAY}│${NC} %-10s ${GRAY}│${NC} %-10s${NC}\n" "TARGET" "MODE" "RESULT"
    draw_sep

    # .config folders
    for entry in "${CONFIG_LIST[@]}"; do
        IFS=":" read -r src dest mode <<< "$entry"
        if [ -d "$CONFIG_DEST/$dest" ]; then
            mkdir -p "$CONFIG_SRC/$src"
            if [ "$mode" == "replace" ]; then
                rsync -az --delete "$CONFIG_DEST/$dest/" "$CONFIG_SRC/$src/"
                print_status "$src" "$mode" "REPLACED" "$RED"
            else
                rsync -az "$CONFIG_DEST/$dest/" "$CONFIG_SRC/$src/"
                print_status "$src" "$mode" "MERGED" "$GREEN"
            fi
        else
            print_status "$src" "$mode" "MISSING" "$YELLOW"
        fi
    done

    # Home files
    for entry in "${HOME_FILES[@]}"; do
        IFS=":" read -r src dest <<< "$entry"
        if [ -f "$DOTFILES_REPO/$dest" ]; then
            mkdir -p "$(dirname "$HOME/$src")"
            rsync -az "$DOTFILES_REPO/$dest" "$HOME/$src"
            print_status "$src" "file" "RESTORED" "$BLUE"
        fi
    done
    
    draw_sep
    echo -e "${GREEN}${BOLD} ✅ System synchronized successfully!${NC}\n"
}

    restore
