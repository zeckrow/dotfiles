#!/bin/bash

# --- Warna untuk UI ---
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'
BOLD='\033[1m'

# --- Konfigurasi ---
DOTFILES_REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG_SRC="$HOME/.config"
CONFIG_DEST="$DOTFILES_REPO/config"

# Daftar file HOME (Asli:Tujuan)
HOME_FILES=(
    ".bashrc:bashrc"
    ".gitconfig:gitconfig"
)

header() {
    echo -e "${BLUE}${BOLD}==========================================${NC}"
    echo -e "${BLUE}${BOLD}   🚀 DOTFILES MANAGER (Default: Restore) ${NC}"
    echo -e "${BLUE}${BOLD}==========================================${NC}"
}

# --- FUNGSI BACKUP (DENGAN PILIHAN) ---
backup() {
    header
    echo -e "${YELLOW}[BACKUP MODE]${NC}"

    echo -e "\nPilih apa yang ingin di-backup:"
    echo -e "1) Semua (.config & Home files)"
    echo -e "2) Hanya folder tertentu di .config"
    echo -e "3) Hanya file Home tertentu"
    read -p "Masukkan pilihan (1/2/3): " choice

    case $choice in
        1)
            # Backup Semua
            mkdir -p "$CONFIG_DEST"
            for dir in "$CONFIG_SRC"/*/; do
                folder=$(basename "$dir")
                rsync -az --delete "$dir" "$CONFIG_DEST/$folder"
                printf "  %-30s ${GREEN}✔️ Synced${NC}\n" "$folder"
            done
            for entry in "${HOME_FILES[@]}"; do
                src="${entry%%:*}"; dest="${entry#*:}"
                [ -f "$HOME/$src" ] && rsync -az "$HOME/$src" "$DOTFILES_REPO/$dest" && printf "  %-30s ${GREEN}✔️ %-20s${NC}\n" "$src" "$dest"
            done
            ;;
        2)
            # Pilih Folder di .config
            echo -e "\nFolder tersedia di $CONFIG_SRC:"
            ls -F "$CONFIG_SRC" | grep '/'
            read -p "Masukkan nama folder (pisahkan dengan spasi): " selected_folders
            for folder in $selected_folders; do
                folder=${folder%/} # hapus trailing slash jika ada
                if [ -d "$CONFIG_SRC/$folder" ]; then
                    mkdir -p "$CONFIG_DEST/$folder"
                    rsync -az --delete "$CONFIG_SRC/$folder/" "$CONFIG_DEST/$folder/"
                    echo -e "  ${GREEN}✔️ $folder berhasil di-backup${NC}"
                else
                    echo -e "  ${RED}❌ $folder tidak ditemukan${NC}"
                fi
            done
            ;;
        3)
            # Pilih File Home
            echo -e "\nFile Home yang terdaftar:"
            for i in "${!HOME_FILES[@]}"; do echo "$i) ${HOME_FILES[$i]%%:*}"; done
            read -p "Masukkan nomor file (pisahkan dengan spasi): " selected_indices
            for idx in $selected_indices; do
                entry="${HOME_FILES[$idx]}"
                src="${entry%%:*}"; dest="${entry#*:}"
                if [ -f "$HOME/$src" ]; then
                    rsync -az "$HOME/$src" "$DOTFILES_REPO/$dest"
                    echo -e "  ${GREEN}✔️ $src di-backup sebagai $dest${NC}"
                fi
            done
            ;;
        *) echo "Pilihan tidak valid.";;
    esac
}

# --- FUNGSI RESTORE (DEFAULT) ---
restore() {
    header
    echo -e "${GREEN}[RESTORE MODE]${NC}"

    # 1. Restore .config
    if [ -d "$CONFIG_DEST" ]; then
        echo -e "\n${BOLD}1. Memulihkan Folder .config${NC}"
        echo "----------------------------------------------------"
        for dir in "$CONFIG_DEST"/*/; do
            [ ! -d "$dir" ] && continue # Lewati jika bukan direktori
            
            folder_name=$(basename "$dir")
            target_dir="$CONFIG_SRC/$folder_name"

            # KRUSIAL: Buat folder tujuan jika belum ada
            mkdir -p "$target_dir"

            # Copy isi folder (tanda / di akhir sangat penting)
            rsync -az "$dir/" "$target_dir/"
            printf "  %-30s ${GREEN}✔️ Restored${NC}\n" "$folder_name"
        done
    fi

    # 2. Restore Home Files
    echo -e "\n${BOLD}2. Memulihkan file Home (Restore dots)${NC}"
    echo "----------------------------------------------------"
    for entry in "${HOME_FILES[@]}"; do
        src="${entry%%:*}"
        dest="${entry#*:}"
        if [ -f "$DOTFILES_REPO/$dest" ]; then
            # Pastikan folder parent file (jika ada) sudah ada
            mkdir -p "$(dirname "$HOME/$src")"
            rsync -az "$DOTFILES_REPO/$dest" "$HOME/$src"
            printf "  %-30s ${GREEN}✔️ %-20s${NC}\n" "$dest" "$src"
        else
            printf "  %-30s ${RED}❌ Missing${NC}\n" "$dest"
        fi
    done
}

# --- LOGIKA EKSEKUSI ---
if [ "$1" == "backup" ]; then
    backup
else
    # Jika tidak ada argumen atau argumennya 'restore'
    restore
fi
